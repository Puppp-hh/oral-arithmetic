# ──────────────────────────────────────────────────────────────
# 环境变量模板
# 使用方式：cp .env.example .env，然后修改对应值
# 注意：.env 文件已加入 .gitignore，切勿将真实密码提交到仓库
# ──────────────────────────────────────────────────────────────

# ── 服务器 ───────────────────────────────────────────────────
PORT=3000
# 本地开发用 development，Docker/生产用 production
NODE_ENV=development

# ── MySQL ───────────────────────────────────────────────────
# 本地直连用 127.0.0.1，Docker 内部用服务名 mysql（docker-compose 自动覆盖）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=oral_arithmetic

# ── Redis ───────────────────────────────────────────────────
# 本地直连用 127.0.0.1，Docker 内部用服务名 redis（docker-compose 自动覆盖）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── JWT ─────────────────────────────────────────────────────
# 生产环境请替换为足够长的随机字符串
JWT_SECRET=change_me_to_a_strong_random_secret
JWT_EXPIRES_IN=7200

# ── Token ───────────────────────────────────────────────────
TOKEN_EXPIRES_IN=7200

# ── 功能开关 ────────────────────────────────────────────────
# 生产环境可设置为 true 关闭 Swagger 文档，避免暴露接口信息
DISABLE_SWAGGER=false

# ── 高德地图 Web 服务 Key ────────────────────────────────────
# 在高德开放平台创建「Web 服务」应用后获取
# https://lbs.amap.com/dev/key/app
AMAP_KEY=your_amap_web_service_key_here
