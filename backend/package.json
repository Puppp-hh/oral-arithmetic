{
  "name": "oral-arithmetic-backend",
  "version": "1.0.0",
  "description": "小学数学口算分级训练系统 - 后端服务",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
