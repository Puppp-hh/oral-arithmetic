/* 错题本样式 */
.page { padding-bottom: 40rpx; }

/* ── 筛选 Tab ── */
.filter-tabs {
  display: flex;
  background: #fff;
  padding: 16rpx 24rpx;
  gap: 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.filter-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #888;
  background: #F5F7FA;
}

.filter-tab.active {
  background: #4A90E2;
  color: #fff;
  font-weight: 600;
}

/* ── 计数 ── */
.count-bar {
  font-size: 24rpx;
  color: #aaa;
  padding: 16rpx 32rpx 8rpx;
}

/* ── 错题卡片 ── */
.mistake-item {
  background: #fff;
  border-radius: 16rpx;
  margin: 12rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
  overflow: hidden;
}

.item-header {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx 24rpx;
}

.item-left { flex: 1; }

.item-content {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.item-tags { display: flex; gap: 12rpx; flex-wrap: wrap; }

.tag-level {
  background: #EBF3FD;
  color: #4A90E2;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  font-size: 22rpx;
}

.tag-type {
  background: #F0F0F0;
  color: #666;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  font-size: 22rpx;
}

.tag-count {
  background: #FFF2F0;
  color: #FF4D4F;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  font-size: 22rpx;
}

.item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.expand-arrow {
  font-size: 24rpx;
  color: #ccc;
  padding: 8rpx;
}

/* ── 展开详情 ── */
.item-detail {
  border-top: 1rpx solid #F5F5F5;
  padding: 24rpx 28rpx;
  background: #FAFAFA;
}

.detail-row {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
}

.detail-label {
  font-size: 24rpx;
  color: #999;
  width: 120rpx;
}

.detail-val {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.correct-val { color: #52C41A; font-weight: 700; font-size: 32rpx; }
.time-val    { font-size: 24rpx; color: #bbb; }

/* 操作按钮 */
.item-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.btn-corrected {
  flex: 1;
  background: #52C41A;
  color: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
  padding: 16rpx 0;
  border: none;
  text-align: center;
}

.btn-delete {
  flex: 1;
  background: #fff;
  color: #FF4D4F;
  border: 2rpx solid #FF4D4F;
  border-radius: 32rpx;
  font-size: 26rpx;
  padding: 16rpx 0;
  text-align: center;
}

/* ── 加载更多 ── */
.load-more {
  text-align: center;
  padding: 32rpx;
  color: #ccc;
  font-size: 26rpx;
}

.no-more { color: #ddd; }

/* ── 空状态 ── */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
  color: #bbb;
  font-size: 28rpx;
}

.empty-icon { font-size: 96rpx; margin-bottom: 24rpx; }

/* 全局标签 */
.tag-correct { color: #52C41A; background: #F6FFED; border: 1rpx solid #B7EB8F; border-radius: 8rpx; padding: 4rpx 14rpx; font-size: 24rpx; }
.tag-wrong   { color: #FF4D4F; background: #FFF2F0; border: 1rpx solid #FFCCC7; border-radius: 8rpx; padding: 4rpx 14rpx; font-size: 24rpx; }
