<!-- 错题本视图 -->
<view class="page">

  <!-- 筛选 Tab -->
  <view class="filter-tabs">
    <view
      wx:for="{{filters}}"
      wx:key="label"
      class="filter-tab {{filterIndex === index ? 'active' : ''}}"
      bindtap="switchFilter"
      data-index="{{index}}"
    >
      {{item.label}}
    </view>
  </view>

  <!-- 统计文字 -->
  <view class="count-bar">
    <text>共 {{total}} 条错题</text>
  </view>

  <!-- 错题列表 -->
  <block wx:if="{{list.length > 0}}">
    <view
      wx:for="{{list}}"
      wx:key="mistake_id"
      class="mistake-item"
    >
      <!-- 题目行 -->
      <view class="item-header" bindtap="toggleExpand" data-id="{{item.mistake_id}}">
        <view class="item-left">
          <text class="item-content">{{item.problem_content}}</text>
          <view class="item-tags">
            <text class="tag-level">Lv.{{item.difficulty_level}}</text>
            <text class="tag-type">{{item.problem_type === 'addition' ? '加法' : item.problem_type === 'subtraction' ? '减法' : item.problem_type === 'multiplication' ? '乘法' : item.problem_type === 'division' ? '除法' : '混合'}}</text>
            <text class="tag-count">错{{item.wrong_count}}次</text>
          </view>
        </view>
        <view class="item-right">
          <text class="{{item.is_corrected ? 'tag-correct' : 'tag-wrong'}}">
            {{item.is_corrected ? '已改正' : '未改正'}}
          </text>
          <text class="expand-arrow">{{expandedId === item.mistake_id ? '∧' : '∨'}}</text>
        </view>
      </view>

      <!-- 展开详情 -->
      <block wx:if="{{expandedId === item.mistake_id}}">
        <view class="item-detail">
          <view class="detail-row">
            <text class="detail-label">正确答案</text>
            <text class="detail-val correct-val">{{item.standard_answer}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">首次错误</text>
            <text class="detail-val">{{item.student_answer}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">错误时间</text>
            <text class="detail-val time-val">{{item.first_wrong_date}}</text>
          </view>

          <!-- 操作按钮 -->
          <view class="item-actions">
            <button
              wx:if="{{!item.is_corrected}}"
              class="btn-corrected"
              bindtap="onMarkCorrected"
              data-id="{{item.mistake_id}}"
            >✓ 标记改正</button>
            <button
              class="btn-delete"
              bindtap="onDelete"
              data-id="{{item.mistake_id}}"
            >🗑 删除</button>
          </view>
        </view>
      </block>
    </view>

    <!-- 加载更多 -->
    <view class="load-more">
      <text wx:if="{{loading}}">加载中...</text>
      <text wx:elif="{{!hasMore}}" class="no-more">— 已加载全部 —</text>
    </view>
  </block>

  <!-- 空状态 -->
  <view wx:if="{{!loading && list.length === 0}}" class="empty-tip">
    <text class="empty-icon">📭</text>
    <text>{{filterIndex === 1 ? '没有未改正的错题，继续保持！' : filterIndex === 2 ? '还没有改正的错题' : '错题本是空的，继续加油！'}}</text>
  </view>

  <!-- 首次加载 -->
  <view wx:if="{{loading && list.length === 0}}" class="empty-tip">
    <text>加载中...</text>
  </view>
</view>
