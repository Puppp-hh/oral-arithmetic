<!-- 首页视图 -->
<view class="page">

  <!-- 顶部用户卡片 -->
  <view class="user-card">
    <view class="user-card__left">
      <view class="avatar">
        <text class="avatar-text">{{userInfo.name ? userInfo.name[0] : '?'}}</text>
      </view>
      <view class="user-info">
        <text class="user-name">{{userInfo.name || userInfo.account}}</text>
        <text class="user-role">{{role === 'student' ? '学生' : '教师'}}</text>
      </view>
    </view>
    <view class="logout-btn" bindtap="onLogout">退出</view>
  </view>

  <!-- 等级横幅（仅学生） -->
  <block wx:if="{{role === 'student' && summary}}">
    <view class="level-banner">
      <view class="level-info">
        <text class="level-num">Lv.{{summary.current_level}}</text>
        <text class="level-title">{{levelTitle}}</text>
      </view>
      <view class="level-progress-wrap">
        <text class="progress-label">正确率 {{summary.cumulative_correct_rate}}%</text>
        <view class="progress-bar">
          <view
            class="progress-fill {{summary.cumulative_correct_rate >= 85 ? 'fill-gold' : 'fill-blue'}}"
            style="width:{{summary.cumulative_correct_rate}}%"
          ></view>
        </view>
        <text class="progress-tip {{summary.is_promotion_qualified ? 'tip-ready' : ''}}">
          {{summary.is_promotion_qualified ? '🎉 满足升级条件！' : '最近20题正确率 ' + summary.recent_20_correct_rate + '%，达到85%可升级'}}
        </text>
      </view>
    </view>

    <!-- 今日统计数字 -->
    <view class="stat-row">
      <view class="stat-item">
        <text class="stat-num">{{summary.total_problems}}</text>
        <text class="stat-label">累计题数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{summary.today_problems}}</text>
        <text class="stat-label">今日题数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{summary.today_correct_rate}}%</text>
        <text class="stat-label">今日正确率</text>
      </view>
    </view>
  </block>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-tip">
    <text>加载中...</text>
  </view>

  <!-- 功能入口 -->
  <view class="section-title">快捷入口</view>
  <view class="menu-grid">
    <view class="menu-item" bindtap="goTrain">
      <text class="menu-icon">✏️</text>
      <text class="menu-label">开始训练</text>
      <text class="menu-desc">随机出题练习</text>
    </view>
    <view class="menu-item" bindtap="goMistakes">
      <text class="menu-icon">📖</text>
      <text class="menu-label">我的错题</text>
      <text class="menu-desc">查看并复习错题</text>
    </view>
    <view class="menu-item" bindtap="goStats">
      <text class="menu-icon">📊</text>
      <text class="menu-label">学习统计</text>
      <text class="menu-desc">查看进步曲线</text>
    </view>
  </view>
</view>
