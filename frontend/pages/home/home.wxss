/* 首页样式 */
.page { padding-bottom: 40rpx; }

/* ── 用户卡片 ── */
.user-card {
  background: linear-gradient(135deg, #4A90E2, #357ABD);
  padding: 48rpx 32rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.user-card__left { display: flex; align-items: center; }

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.avatar-text { font-size: 40rpx; color: #fff; font-weight: 700; }

.user-name { display: block; font-size: 36rpx; font-weight: 600; color: #fff; }
.user-role { font-size: 24rpx; color: rgba(255,255,255,0.75); margin-top: 4rpx; }

.logout-btn {
  background: rgba(255,255,255,0.2);
  color: #fff;
  border-radius: 32rpx;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
}

/* ── 等级横幅 ── */
.level-banner {
  background: #fff;
  margin: 20rpx 24rpx 0;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

.level-info { display: flex; align-items: center; margin-bottom: 20rpx; }

.level-num {
  font-size: 48rpx;
  font-weight: 800;
  color: #4A90E2;
  margin-right: 16rpx;
}

.level-title { font-size: 30rpx; color: #333; font-weight: 600; }

.progress-label { font-size: 24rpx; color: #888; margin-bottom: 10rpx; display: block; }

.progress-bar {
  height: 16rpx;
  background: #F0F0F0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.fill-blue { background: linear-gradient(90deg, #4A90E2, #6EC6FF); }
.fill-gold { background: linear-gradient(90deg, #F5A623, #FFD700); }

.progress-tip { font-size: 22rpx; color: #999; }
.tip-ready { color: #52C41A; font-weight: 600; }

/* ── 统计数字行 ── */
.stat-row {
  background: #fff;
  margin: 16rpx 24rpx 0;
  border-radius: 16rpx;
  padding: 28rpx 0;
  display: flex;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

.stat-item { flex: 1; text-align: center; }

.stat-num {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: #4A90E2;
}

.stat-label { font-size: 22rpx; color: #999; margin-top: 6rpx; }

.stat-divider { width: 1rpx; background: #F0F0F0; }

/* ── 功能入口 ── */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  padding: 32rpx 32rpx 16rpx;
}

.menu-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 24rpx;
}

.menu-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.menu-item:active { opacity: 0.85; transform: scale(0.99); }

.menu-icon { font-size: 56rpx; margin-right: 24rpx; }

.menu-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.menu-desc { font-size: 24rpx; color: #aaa; }

.loading-tip {
  text-align: center;
  padding: 40rpx;
  color: #bbb;
}
