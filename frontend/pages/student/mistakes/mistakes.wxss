.page-container {
  min-height: 100vh;
  padding: 28rpx;
  background: #f5f5f7;
  box-sizing: border-box;
}

.mistake-hero {
  padding: 18rpx 4rpx 26rpx;
  display: flex;
  flex-direction: column;
}

.hero-title {
  font-size: 48rpx;
  line-height: 1.15;
  font-weight: 700;
  color: #1d1d1f;
}

.hero-subtitle {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.45;
  color: #6e6e73;
}

.tabs {
  display: flex;
  gap: 12rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  background: #e9e9ee;
  border-radius: 20rpx;
}

.tab-item {
  flex: 1;
  min-height: 68rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  font-size: 27rpx;
  color: #6e6e73;
}

.tab-item.active {
  background: #fff;
  color: #1d1d1f;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.07);
}

.tab-count {
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.06);
  color: #6e6e73;
  font-size: 22rpx;
  line-height: 34rpx;
  text-align: center;
}

.tab-item.active .tab-count {
  background: #007aff;
  color: #fff;
}

.list-wrap {
  padding-bottom: 32rpx;
}

.mistake-item {
  background: #fff;
  border-radius: 26rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.04);
}

.mi-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.type-tag {
  background: #f2f2f7;
  color: #3a3a3c;
  font-size: 23rpx;
  line-height: 1.5;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
}

.wrong-count {
  font-size: 23rpx;
  color: #d92d20;
}

.mi-problem {
  padding: 22rpx 0 28rpx;
}

.problem-content {
  font-size: 46rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #1d1d1f;
}

.mi-answers {
  background: #f8f8fa;
  border-radius: 18rpx;
  padding: 18rpx 22rpx;
  margin-bottom: 22rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.answer-line {
  display: flex;
  align-items: center;
  min-height: 54rpx;
}

.al-label {
  width: 150rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  color: #86868b;
}

.al-val {
  font-size: 30rpx;
  font-weight: 650;
  color: #1d1d1f;
}

.al-val.wrong {
  color: #d92d20;
  text-decoration: line-through;
}

.al-val.correct {
  color: #128a4a;
}

.mi-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.date-group {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.date-text {
  font-size: 22rpx;
  color: #8e8e93;
}

.date-text.mastered {
  color: #128a4a;
}

.mi-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.btn-redo,
.btn-master,
.mastered-badge {
  min-width: 104rpx;
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.btn-redo {
  background: #f2f2f7;
  color: #1d1d1f;
}

.btn-master {
  background: #007aff;
  color: #fff;
}

.mastered-badge {
  background: #e8f8ef;
  color: #128a4a;
}

.empty-state {
  min-height: 420rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  color: #8e8e93;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
}

.empty-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8e8e93;
}

.loading-wrap,
.no-more {
  text-align: center;
  font-size: 24rpx;
  color: #8e8e93;
  padding: 36rpx 0;
}
