<view class="page-container">
  <view class="form-card">
    <view class="form-item">
      <text class="form-label">原密码</text>
      <input
        class="form-input"
        password
        placeholder="请输入原密码"
        value="{{oldPassword}}"
        data-field="oldPassword"
        bindinput="onInput"
        confirm-type="next"
      />
    </view>

    <view class="form-item">
      <text class="form-label">新密码</text>
      <input
        class="form-input"
        password
        placeholder="至少 6 位"
        value="{{newPassword}}"
        data-field="newPassword"
        bindinput="onInput"
        confirm-type="next"
      />
    </view>

    <view class="form-item">
      <text class="form-label">确认新密码</text>
      <input
        class="form-input"
        password
        placeholder="再次输入新密码"
        value="{{confirmPassword}}"
        data-field="confirmPassword"
        bindinput="onInput"
        bindconfirm="onSubmit"
        confirm-type="done"
      />
    </view>

    <button class="btn-submit" disabled="{{loading}}" bindtap="onSubmit">
      {{loading ? '提交中...' : '重置密码'}}
    </button>
  </view>
</view>
