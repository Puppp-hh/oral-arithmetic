.page-container {
  min-height: 100vh;
  background: #F4F7FB;
  padding: 32rpx 24rpx;
  box-sizing: border-box;
}

.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 8rpx 28rpx rgba(31, 111, 235, 0.08);
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #4b5563;
  margin-bottom: 14rpx;
  font-weight: 600;
}

.form-input {
  width: 100%;
  height: 88rpx;
  border-radius: 16rpx;
  background: #F7F9FC;
  border: 2rpx solid #E5EAF2;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #1f2937;
}

.btn-submit {
  width: 100%;
  height: 92rpx;
  border-radius: 46rpx;
  background: #1F6FEB;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin-top: 16rpx;
}

.btn-submit[disabled] {
  background: #A8C7FA;
}
