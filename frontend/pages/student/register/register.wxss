.reg-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1F6FEB 0%, #3d8ef8 36%, #F4F7FB 36%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.reg-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 0 48rpx;
}

.reg-logo {
  width: 108rpx;
  height: 108rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.logo-icon {
  font-size: 72rpx;
  color: #fff;
  font-weight: bold;
  line-height: 1;
}

.reg-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
}

.reg-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.reg-form {
  width: 686rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.1);
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  background: #fafafa;
}

.invite-input {
  letter-spacing: 4rpx;
  font-weight: 600;
  color: #1F6FEB;
}

.form-hint {
  display: block;
  font-size: 22rpx;
  color: #aaa;
  margin-top: 8rpx;
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  background: #1F6FEB;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 8rpx;
  border: none;
  letter-spacing: 4rpx;
}

.btn-submit[disabled] {
  background: #a0bfef;
}

.footer-links {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 36rpx;
}

.link-text {
  font-size: 26rpx;
  color: #999;
}

.link-btn {
  font-size: 26rpx;
  color: #1F6FEB;
  margin-left: 8rpx;
}
