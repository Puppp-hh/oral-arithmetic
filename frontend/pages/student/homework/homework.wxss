.page-container {
  min-height: 100vh;
  padding: 24rpx 28rpx;
  background: #f5f5f7;
  box-sizing: border-box;
}

.tabs {
  display: flex;
  gap: 12rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  background: #e9e9ee;
  border-radius: 20rpx;
}

.tab-item {
  flex: 1;
  min-height: 68rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 27rpx;
  color: #6e6e73;
}

.tab-item.active {
  background: #fff;
  color: #1d1d1f;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.07);
}

.list-wrap {
  padding-bottom: 32rpx;
}

.hw-item {
  background: #fff;
  border-radius: 26rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 14rpx 34rpx rgba(0, 0, 0, 0.035);
}

.hw-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.hw-title {
  flex: 1;
  font-size: 31rpx;
  line-height: 1.35;
  font-weight: 650;
  color: #1d1d1f;
}

.hw-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 10rpx;
}

.meta-text {
  font-size: 24rpx;
  color: #6e6e73;
  line-height: 1.5;
}

.meta-dot {
  font-size: 24rpx;
  color: #c7c7cc;
  margin: 0 12rpx;
}

.hw-footer {
  display: flex;
  align-items: center;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.score-text {
  font-size: 26rpx;
  color: #007aff;
  font-weight: 650;
  margin-right: 24rpx;
}

.rate-text {
  font-size: 24rpx;
  color: #6e6e73;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.tag-warning { background: #fff6e0; color: #b85d00; }
.tag-success { background: #e8f8ef; color: #128a4a; }

.empty-state {
  min-height: 380rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #8e8e93;
  font-size: 27rpx;
}

.error-state {
  min-height: 380rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 18rpx;
  color: #8e8e93;
  font-size: 26rpx;
}

.error-title {
  font-size: 30rpx;
  font-weight: 650;
  color: #1d1d1f;
}

.error-desc {
  max-width: 560rpx;
  text-align: center;
  line-height: 1.5;
}

.btn-retry {
  height: 64rpx;
  padding: 0 36rpx;
  border-radius: 18rpx;
  background: #007aff;
  color: #fff;
  font-size: 26rpx;
  border: none;
  line-height: 64rpx;
}

.loading-wrap,
.no-more {
  text-align: center;
  font-size: 24rpx;
  color: #8e8e93;
  padding: 36rpx 0;
}
