.page-container {
  padding: 24rpx;
  min-height: 100vh;
  background: #F4F7FB;
  padding-bottom: 120rpx;
}

/* 成绩卡 */
.result-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.result-title {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.exam-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #222;
  display: block;
  margin-bottom: 40rpx;
}

.result-score-wrap {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  margin-bottom: 8rpx;
}

.score-num {
  font-size: 112rpx;
  font-weight: bold;
  color: #1F6FEB;
  line-height: 1;
}

.score-total {
  font-size: 36rpx;
  color: #999;
  margin-bottom: 12rpx;
  margin-left: 8rpx;
}

.result-stats {
  display: flex;
  justify-content: space-around;
  margin-top: 40rpx;
}

.rs-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.rs-num {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
}

.rs-num.correct { color: #07a65a; }
.rs-num.wrong   { color: #f5222d; }

.rs-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.pending-grade {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-top: 32rpx;
}

/* 考试 Header */
.exam-header-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.exam-info {
  display: flex;
  flex-direction: column;
}

.exam-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #222;
}

.exam-count {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.countdown {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #e8f0fe;
  border-radius: 12rpx;
  padding: 12rpx 24rpx;
}

.countdown.danger {
  background: #fff1f0;
}

.countdown-label {
  font-size: 20rpx;
  color: #1F6FEB;
}

.countdown.danger .countdown-label {
  color: #f5222d;
}

.countdown-time {
  font-size: 36rpx;
  font-weight: bold;
  color: #1F6FEB;
  font-family: 'Courier New', monospace;
}

.countdown.danger .countdown-time {
  color: #f5222d;
}

/* 题目 */
.problem-item {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.problem-num-badge {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #1F6FEB;
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
  margin-top: 4rpx;
}

.problem-content {
  font-size: 36rpx;
  font-weight: bold;
  color: #222;
  display: block;
  margin-bottom: 20rpx;
}

.answer-row {
  display: flex;
  align-items: center;
}

.answer-eq {
  font-size: 32rpx;
  color: #999;
  margin-right: 16rpx;
}

.answer-input {
  width: 160rpx;
  height: 64rpx;
  border-bottom: 2rpx solid #1F6FEB;
  font-size: 32rpx;
  color: #1F6FEB;
  font-weight: bold;
  text-align: center;
}

/* 提交 */
.submit-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 40rpx 40rpx;
  background: rgba(244, 247, 251, 0.95);
}

.btn-submit {
  width: 100%;
  height: 96rpx;
  background: #1F6FEB;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  letter-spacing: 4rpx;
}

.btn-submit[disabled] { background: #a0bfef; }

.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 300rpx;
  color: #bbb;
  font-size: 28rpx;
}
