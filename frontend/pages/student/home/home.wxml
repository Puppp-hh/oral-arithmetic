<view class="home-container">

  <!-- 顶部用户信息卡 -->
  <view class="user-card">
    <view class="user-info">
      <view class="avatar">
        <text class="avatar-text">{{userInfo.name ? userInfo.name[0] : '?'}}</text>
      </view>
      <view class="user-meta">
        <text class="user-name">{{userInfo.name || userInfo.account}}</text>
        <view class="level-badge">
          <text class="level-text">Lv.{{levelInfo.current_level || 1}} {{levelInfo.level_title || '口算萌新'}}</text>
        </view>
      </view>
    </view>
    <text class="logout-btn" bindtap="onLogout">退出</text>
  </view>

  <!-- 今日概况 -->
  <view class="section-title">今日概况 · {{todayDate}}</view>
  <view class="stats-row">
    <view class="stat-item">
      <text class="stat-num">{{statsOverview.today_problems || 0}}</text>
      <text class="stat-label">今日题数</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{statsOverview.today_correct_rate || '0%'}}</text>
      <text class="stat-label">今日正确率</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{statsOverview.total_problems || 0}}</text>
      <text class="stat-label">累计题数</text>
    </view>
  </view>

  <!-- 待完成提醒 -->
  <view class="todo-row" wx:if="{{pendingHomeworkCount > 0 || pendingExamCount > 0}}">
    <view class="todo-item warn" wx:if="{{pendingHomeworkCount > 0}}" bindtap="goHomework">
      <text class="todo-icon">!</text>
      <text class="todo-text">有 {{pendingHomeworkCount}} 份作业待完成</text>
    </view>
    <view class="todo-item danger" wx:if="{{pendingExamCount > 0}}" bindtap="goExam">
      <text class="todo-icon">!</text>
      <text class="todo-text">有 {{pendingExamCount}} 场考试待参加</text>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="section-title">功能</view>
  <view class="menu-grid">
    <view class="menu-item blue" bindtap="goTrain">
      <text class="menu-icon">+−</text>
      <text class="menu-label">口算训练</text>
      <text class="menu-desc">今日练习</text>
    </view>
    <view class="menu-item green" bindtap="goHomework">
      <text class="menu-icon">作</text>
      <text class="menu-label">家庭作业</text>
      <text class="menu-desc" wx:if="{{pendingHomeworkCount > 0}}">待完成 {{pendingHomeworkCount}}</text>
      <text class="menu-desc" wx:else>查看作业</text>
    </view>
    <view class="menu-item orange" bindtap="goExam">
      <text class="menu-icon">考</text>
      <text class="menu-label">在线考试</text>
      <text class="menu-desc" wx:if="{{pendingExamCount > 0}}">待参加 {{pendingExamCount}}</text>
      <text class="menu-desc" wx:else>查看考试</text>
    </view>
    <view class="menu-item red" bindtap="goMistakes">
      <text class="menu-icon">错</text>
      <text class="menu-label">错题本</text>
      <text class="menu-desc">查看错题</text>
    </view>
    <view class="menu-item purple" bindtap="goStats">
      <text class="menu-icon">统</text>
      <text class="menu-label">学习统计</text>
      <text class="menu-desc">查看报告</text>
    </view>
    <view class="menu-item slate" bindtap="goResetPwd">
      <text class="menu-icon">密</text>
      <text class="menu-label">重置密码</text>
      <text class="menu-desc">修改登录密码</text>
    </view>
  </view>

</view>
