.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1F6FEB 0%, #2F7FF3 34%, #F5F7FB 34%);
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  padding: 0 32rpx 48rpx;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 88rpx 0 52rpx;
}

.login-logo {
  width: 128rpx;
  height: 128rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.28);
}

.logo-icon {
  font-size: 80rpx;
  color: #fff;
  font-weight: bold;
  line-height: 1;
}

.login-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.login-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.login-form {
  width: 100%;
  max-width: 686rpx;
  background: #fff;
  border-radius: 30rpx;
  padding: 46rpx 40rpx 38rpx;
  box-shadow: 0 18rpx 46rpx rgba(31, 111, 235, 0.16);
  box-sizing: border-box;
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 18rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  background: #f8fafc;
  color: #1d1d1f;
}

.btn-login {
  width: 100%;
  height: 88rpx;
  background: #1F6FEB;
  color: #fff;
  border-radius: 22rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 12rpx;
  border: none;
  letter-spacing: 2rpx;
  box-shadow: 0 12rpx 26rpx rgba(31, 111, 235, 0.24);
}

.btn-login[disabled] {
  background: #a0bfef;
}

.register-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 28rpx;
}

.register-text {
  font-size: 26rpx;
  color: #999;
}

.register-link {
  font-size: 26rpx;
  color: #1F6FEB;
  font-weight: 600;
  margin-left: 8rpx;
}

.switch-role {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
}

.switch-text {
  font-size: 26rpx;
  color: #999;
}

.switch-link {
  font-size: 26rpx;
  color: #1F6FEB;
  margin-left: 8rpx;
}
