<view class="login-container">
  <view class="login-header">
    <view class="login-logo">
      <text class="logo-icon">S</text>
    </view>
    <text class="login-title">口算训练</text>
    <text class="login-subtitle">学生端</text>
  </view>

  <view class="login-form">
    <view class="form-item">
      <text class="form-label">学号</text>
      <input
        class="form-input"
        placeholder="请输入学号"
        value="{{account}}"
        bindinput="onAccountInput"
        maxlength="20"
        confirm-type="next"
      />
    </view>

    <view class="form-item">
      <text class="form-label">密码</text>
      <input
        class="form-input"
        placeholder="请输入密码"
        password="{{true}}"
        value="{{password}}"
        bindinput="onPasswordInput"
        maxlength="30"
        confirm-type="done"
        bindconfirm="onLogin"
      />
    </view>

    <button
      class="btn-login"
      disabled="{{loading}}"
      bindtap="onLogin"
    >{{loading ? '登录中...' : '登 录'}}</button>

    <view class="register-row">
      <text class="register-text">没有账号？</text>
      <text class="register-link" bindtap="goRegister">立即注册</text>
    </view>

    <view class="switch-role">
      <text class="switch-text">我是老师？</text>
      <text class="switch-link" bindtap="goTeacherLogin">切换到教师端</text>
    </view>
  </view>
</view>
