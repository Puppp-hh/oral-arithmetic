.train-container {
  padding: 28rpx;
  min-height: 100vh;
  background: #f5f5f7;
  box-sizing: border-box;
}

/* 进度 */
.progress-wrap {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background: #e5e5ea;
  border-radius: 4rpx;
  margin-right: 16rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #007aff;
  border-radius: 4rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 24rpx;
  color: #6e6e73;
  white-space: nowrap;
}

/* 题目卡片 */
.problem-card {
  background: #fff;
  border-radius: 30rpx;
  padding: 48rpx 40rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 18rpx 42rpx rgba(0, 0, 0, 0.045);
  min-height: 480rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.problem-type-tag {
  font-size: 22rpx;
  color: #007aff;
  background: #e9f3ff;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 40rpx;
}

.problem-content {
  font-size: 68rpx;
  font-weight: bold;
  color: #1d1d1f;
  margin-bottom: 40rpx;
  text-align: center;
}

/* 答案区 */
.answer-row,
.result-row {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  margin-bottom: 40rpx;
}

.answer-eq {
  font-size: 48rpx;
  font-weight: bold;
  color: #8e8e93;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.answer-input {
  width: 300rpx;
  height: 92rpx;
  border: 2rpx solid #d9e8ff;
  border-radius: 22rpx;
  background: #f7fbff;
  font-size: 46rpx;
  font-weight: bold;
  color: #007aff;
  text-align: center;
  box-sizing: border-box;
  padding: 0 24rpx;
}

.answer-placeholder {
  font-size: 28rpx;
  font-weight: 400;
  color: #a3a8b3;
}

.my-answer {
  font-size: 56rpx;
  font-weight: bold;
}

.my-answer.correct { color: #128a4a; }
.my-answer.wrong   { color: #d92d20; text-decoration: line-through; }

/* 结果反馈 */
.feedback-card {
  display: flex;
  align-items: center;
  border-radius: 22rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 40rpx;
  width: 100%;
  box-sizing: border-box;
}

.feedback-card.correct-bg { background: #e8f8ef; }
.feedback-card.wrong-bg   { background: #fff0f0; }

.feedback-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.feedback-title {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
}

.feedback-card.correct-bg .feedback-title { color: #128a4a; }
.feedback-card.wrong-bg .feedback-title   { color: #d92d20; }

.feedback-answer {
  font-size: 26rpx;
  color: #6e6e73;
  margin-top: 6rpx;
  display: block;
}

/* 按钮 */
.btn-confirm {
  width: 100%;
  height: 88rpx;
  background: #007aff;
  color: #fff;
  border-radius: 18rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.btn-confirm.loading { background: #a9d3ff; }

.btn-next {
  width: 100%;
  height: 88rpx;
  background: #007aff;
  color: #fff;
  border-radius: 18rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

/* 顶部配置按钮 */
.top-bar {
  display: flex;
  justify-content: flex-end;
  margin-top: 24rpx;
}

.config-toggle {
  font-size: 26rpx;
  color: #6e6e73;
  padding: 8rpx 16rpx;
}

/* 配置面板 */
.config-panel {
  background: #fff;
  border-radius: 30rpx;
  padding: 40rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 18rpx 42rpx rgba(0, 0, 0, 0.045);
}

.config-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1d1d1f;
  margin-bottom: 32rpx;
}

.config-row {
  margin-bottom: 32rpx;
}

.config-label {
  font-size: 26rpx;
  color: #6e6e73;
  display: block;
  margin-bottom: 16rpx;
}

.option-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.option-btn {
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  background: #f2f2f7;
  color: #3a3a3c;
  border: 2rpx solid transparent;
}

.option-btn.active {
  background: #e9f3ff;
  color: #007aff;
  border-color: #007aff;
}

.option-btn.disabled {
  background: #f1f2f4;
  color: #b8bcc5;
  border-color: transparent;
  opacity: 0.72;
}

.count-options {
  gap: 14rpx;
}

.count-option {
  min-width: 96rpx;
  text-align: center;
}

.btn-apply {
  width: 100%;
  height: 88rpx;
  background: #007aff;
  color: #fff;
  border-radius: 18rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin-top: 16rpx;
}

/* 结果卡 */
.summary-card {
  background: #fff;
  border-radius: 30rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 18rpx 42rpx rgba(0, 0, 0, 0.045);
}

.summary-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1d1d1f;
  margin-bottom: 32rpx;
}

.summary-score {
  display: flex;
  align-items: flex-end;
  margin-bottom: 8rpx;
}

.score-num {
  font-size: 112rpx;
  font-weight: bold;
  color: #007aff;
  line-height: 1;
}

.score-unit {
  font-size: 48rpx;
  color: #007aff;
  margin-bottom: 12rpx;
  margin-left: 4rpx;
}

.score-label {
  font-size: 26rpx;
  color: #6e6e73;
  margin-bottom: 48rpx;
}

.summary-detail {
  display: flex;
  width: 100%;
  justify-content: space-around;
  margin-bottom: 48rpx;
}

.detail-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #1d1d1f;
}

.detail-num.correct { color: #128a4a; }
.detail-num.wrong   { color: #d92d20; }

.detail-label {
  font-size: 24rpx;
  color: #6e6e73;
  margin-top: 8rpx;
}

.btn-again {
  width: 100%;
  height: 88rpx;
  background: #007aff;
  color: #fff;
  border-radius: 18rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin-bottom: 20rpx;
}

.btn-back {
  width: 100%;
  height: 88rpx;
  background: #fff;
  color: #007aff;
  border-radius: 18rpx;
  font-size: 32rpx;
  border: 1rpx solid rgba(0, 122, 255, 0.28);
}
