.page-container {
  padding: 24rpx;
  min-height: 100vh;
  background: #F4F7FB;
  padding-bottom: 60rpx;
}

.form-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.form-item { padding: 24rpx 0; }

.form-label {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #fafafa;
}

/* 分区标题 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.total-info {
  font-size: 24rpx;
  color: #1F6FEB;
  font-weight: 600;
}

/* 题目组卡片 */
.group-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.group-num {
  font-size: 26rpx;
  font-weight: 600;
  color: #2d3a4a;
}

.group-remove {
  font-size: 24rpx;
  color: #f5222d;
}

.group-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.group-row:last-child { border-bottom: none; }

.group-label {
  font-size: 26rpx;
  color: #666;
}

.num-input {
  width: 120rpx;
  height: 64rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  text-align: center;
  box-sizing: border-box;
}

.picker-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #333;
}

.picker-arrow { color: #ccc; }

/* 添加组按钮 */
.btn-add-group {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 24rpx;
  border: 2rpx dashed #ddd;
}

/* 预览 */
.preview-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.preview-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.preview-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.preview-item:last-child { border-bottom: none; }

.preview-num {
  font-size: 24rpx;
  color: #999;
  width: 48rpx;
  flex-shrink: 0;
}

.preview-content {
  flex: 1;
  font-size: 28rpx;
  font-weight: bold;
  color: #222;
  letter-spacing: 2rpx;
}

.preview-score {
  font-size: 22rpx;
  color: #1F6FEB;
  margin-left: 16rpx;
}

/* 操作按钮 */
.action-row {
  display: flex;
  gap: 20rpx;
}

.btn-preview {
  flex: 1;
  height: 88rpx;
  background: #fff;
  color: #2d3a4a;
  border: 2rpx solid #2d3a4a;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-preview[disabled] { opacity: 0.5; }

.btn-save {
  flex: 1;
  height: 88rpx;
  background: #2d3a4a;
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-save[disabled] { background: #8a9aaa; }
