.page-container {
  padding: 24rpx;
  min-height: 100vh;
  background: #F4F7FB;
}

.info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.hw-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #222;
  display: block;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-top: 1rpx solid #f5f5f5;
}

.info-label { font-size: 26rpx; color: #999; }
.info-val   { font-size: 26rpx; color: #333; }

/* 进度卡 */
.progress-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.progress-num-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.pn-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.pn-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #1F6FEB;
}

.pn-num.total { color: #333; }
.pn-num.rate  { color: #07a65a; }

.pn-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.progress-bar-wrap {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #07a65a;
  border-radius: 6rpx;
  transition: width 0.3s;
}

/* Tabs */
.tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx 16rpx 0 0;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 26rpx;
  color: #999;
  position: relative;
}

.tab-item.active {
  color: #2d3a4a;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  width: 50%;
  height: 4rpx;
  background: #2d3a4a;
  border-radius: 2rpx;
}

/* 学生列表 */
.student-list {
  background: #fff;
  border-radius: 0 0 16rpx 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.student-row {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.student-row:last-child { border-bottom: none; }

.sr-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #e8f0fe;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.sr-avatar-text {
  font-size: 28rpx;
  color: #1F6FEB;
  font-weight: bold;
}

.sr-info { flex: 1; }

.sr-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #222;
  display: block;
}

.sr-time {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.sr-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.sr-score {
  font-size: 24rpx;
  font-weight: 600;
  color: #1F6FEB;
}

.tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
}

.tag-success { background: #e6f7f0; color: #07a65a; }
.tag-default { background: #f5f5f5; color: #999; }

.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 200rpx;
  color: #bbb;
  font-size: 28rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 300rpx;
  color: #bbb;
  font-size: 28rpx;
}
