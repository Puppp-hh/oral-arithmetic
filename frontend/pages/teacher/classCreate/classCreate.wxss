.page-container {
  min-height: 100vh;
  background: #F4F7FB;
  padding: 32rpx 24rpx;
  box-sizing: border-box;
}

.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 提示条 */
.form-tip {
  display: flex;
  align-items: flex-start;
  background: #e8f0fe;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 40rpx;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 24rpx;
  color: #1F6FEB;
  line-height: 1.6;
}

/* 表单 */
.form-item {
  margin-bottom: 36rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #444;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 96rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 0 28rpx;
  font-size: 32rpx;
  box-sizing: border-box;
  background: #fafafa;
  color: #222;
}

/* 年级选择器 */
.picker-row {
  height: 96rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 0 28rpx;
  background: #fafafa;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-value {
  font-size: 32rpx;
  color: #222;
}

.picker-arrow {
  font-size: 40rpx;
  color: #bbb;
}

.preview-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #F7F9FC;
  border-radius: 14rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 28rpx;
}

.preview-label {
  font-size: 24rpx;
  color: #6b7280;
}

.preview-name {
  font-size: 30rpx;
  color: #1F6FEB;
  font-weight: 700;
}

/* 按钮 */
.btn-submit {
  width: 100%;
  height: 96rpx;
  background: #1F6FEB;
  color: #fff;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 600;
  border: none;
  margin-top: 16rpx;
  letter-spacing: 4rpx;
}

.btn-submit[disabled] {
  background: #a0bfef;
}
