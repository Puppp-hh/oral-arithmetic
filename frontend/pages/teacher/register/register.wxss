.reg-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #2d3a4a 0%, #3d4e60 32%, #F4F7FB 32%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.reg-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 0 40rpx;
}

.reg-logo {
  width: 108rpx;
  height: 108rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.logo-icon {
  font-size: 64rpx;
  color: #fff;
  font-weight: bold;
  line-height: 1;
}

.reg-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
}

.reg-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
}

.reg-form {
  width: 686rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.1);
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.required {
  color: #f5222d;
  font-size: 24rpx;
}

.optional {
  color: #bbb;
  font-size: 22rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  background: #fafafa;
}

.form-hint {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9aa3ad;
  line-height: 1.4;
}

.school-search-row {
  display: flex;
  align-items: center;
}

.school-input {
  width: 100%;
}

.school-assist {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #9aa3ad;
  line-height: 1.4;
}

.school-selected {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #07a65a;
  line-height: 1.4;
}

.school-result-list {
  margin-top: 14rpx;
  max-height: 360rpx;
  border: 2rpx solid #eef0f3;
  border-radius: 16rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 12rpx 32rpx rgba(20, 33, 48, 0.08);
  box-sizing: border-box;
}

.school-result-item {
  padding: 18rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.school-result-item:last-child {
  border-bottom: none;
}

.school-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #222;
}

.school-address {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #999;
  line-height: 1.4;
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  background: #2d3a4a;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 8rpx;
  border: none;
  letter-spacing: 4rpx;
}

.btn-submit[disabled] {
  background: #8a96a3;
}

.footer-links {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 36rpx;
}

.link-text {
  font-size: 26rpx;
  color: #999;
}

.link-btn {
  font-size: 26rpx;
  color: #1F6FEB;
  margin-left: 8rpx;
}
