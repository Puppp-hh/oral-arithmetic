.page-container {
  padding: 24rpx;
  min-height: 100vh;
  background: #F4F7FB;
}

.info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.card-header {
  padding: 28rpx 0 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
  margin-bottom: 8rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.info-row:last-of-type {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.info-val {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.tag-success { background: #e6f7f0; color: #07a65a; }
.tag-danger  { background: #fff1f0; color: #f5222d; }

/* 密码管理 */
.pwd-section {
  padding: 24rpx 0 32rpx;
}

.pwd-notice {
  font-size: 22rpx;
  color: #fa8c16;
  display: block;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.btn-reset-pwd {
  width: 100%;
  height: 80rpx;
  background: #fff;
  color: #f5222d;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: 2rpx solid #f5222d;
}

.btn-reset-pwd[disabled] { opacity: 0.5; }

/* 统计 */
.stats-row {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 0;
}

.s-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.s-num {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
}

.s-num.rate { color: #1F6FEB; }

.s-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 日趋势 */
.daily-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.daily-date {
  font-size: 24rpx;
  color: #999;
  width: 80rpx;
  flex-shrink: 0;
}

.bar-wrap {
  flex: 1;
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
  margin: 0 16rpx;
}

.bar-fill {
  height: 100%;
  background: #1F6FEB;
  border-radius: 6rpx;
}

.daily-rate {
  font-size: 22rpx;
  color: #333;
  font-weight: 600;
  width: 68rpx;
  text-align: right;
}

.daily-count {
  font-size: 20rpx;
  color: #ccc;
  width: 72rpx;
  text-align: right;
  margin-left: 8rpx;
}

/* 临时密码弹窗 */
.pwd-modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.pwd-modal {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  text-align: center;
}

.pwd-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #222;
  display: block;
  margin-bottom: 24rpx;
}

.pwd-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #f5222d;
  letter-spacing: 8rpx;
  display: block;
  background: #fff1f0;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.pwd-modal-notice {
  font-size: 22rpx;
  color: #fa8c16;
  line-height: 1.6;
  display: block;
  margin-bottom: 32rpx;
}

.btn-close-pwd {
  width: 100%;
  height: 80rpx;
  background: #2d3a4a;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 300rpx;
  color: #bbb;
  font-size: 28rpx;
}
