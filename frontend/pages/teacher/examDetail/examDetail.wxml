<view class="page-container">
  <view class="loading-wrap" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <block wx:if="{{!loading && exam}}">
    <!-- 考试基本信息 -->
    <view class="info-card">
      <text class="exam-title">{{exam.title}}</text>
      <view class="info-row">
        <text class="info-label">考试时间</text>
        <text class="info-val">{{exam.startTimeText}} ~ {{exam.endTimeText}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">时长 / 题数</text>
        <text class="info-val">{{exam.duration_minutes}} 分钟 / {{exam.problem_count}} 道</text>
      </view>
      <view class="info-row">
        <text class="info-label">状态</text>
        <view class="tag tag-{{exam.status === 'published' ? 'primary' : (exam.status === 'finished' ? 'default' : 'warning')}}">
          {{exam.statusLabel}}
        </view>
      </view>
    </view>

    <!-- 提交统计 -->
    <view class="stats-card" wx:if="{{examStats}}">
      <view class="stats-row">
        <view class="s-cell">
          <text class="s-num">{{examStats.submitted}}</text>
          <text class="s-label">已提交</text>
        </view>
        <view class="s-cell">
          <text class="s-num total">{{examStats.total}}</text>
          <text class="s-label">应参加</text>
        </view>
        <view class="s-cell">
          <text class="s-num rate">{{examStats.avg_rate}}</text>
          <text class="s-label">平均正确率</text>
        </view>
        <view class="s-cell">
          <text class="s-num">{{examStats.avg_score}}</text>
          <text class="s-label">平均分</text>
        </view>
      </view>
    </view>

    <!-- 学生成绩列表 -->
    <view class="section-title" wx:if="{{studentScores.length > 0}}">学生成绩</view>
    <view class="score-list">
      <view
        class="score-row"
        wx:for="{{studentScores}}"
        wx:key="student_id"
      >
        <view class="sr-rank">{{index + 1}}</view>
        <view class="sr-avatar">
          <text class="sr-avatar-text">{{item.name ? item.name[0] : '?'}}</text>
        </view>
        <view class="sr-info">
          <text class="sr-name">{{item.name}}</text>
          <text class="sr-rate">正确率 {{item.correct_rate}}</text>
        </view>
        <text class="sr-score">{{item.score}} 分</text>
      </view>

      <view class="empty-state" wx:if="{{studentScores.length === 0 && !loading}}">
        <text>暂无提交数据</text>
      </view>
    </view>
  </block>
</view>
