.page-container { padding: 24rpx; background: #F4F7FB; min-height: 100vh; }
.loading-wrap { display: flex; justify-content: center; padding: 80rpx; color: #999; }
.info-card { background: #fff; border-radius: 16rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,.06); }
.exam-title { font-size: 34rpx; font-weight: bold; color: #1a1a1a; display: block; margin-bottom: 24rpx; }
.info-row { display: flex; align-items: center; padding: 12rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.info-row:last-child { border-bottom: none; }
.info-label { font-size: 26rpx; color: #888; width: 180rpx; flex-shrink: 0; }
.info-val { font-size: 28rpx; color: #333; flex: 1; }
.tag { display: inline-block; padding: 4rpx 16rpx; border-radius: 20rpx; font-size: 22rpx; }
.tag-primary { background: #e8f0fe; color: #1F6FEB; }
.tag-default { background: #f0f0f0; color: #666; }
.tag-warning { background: #fff8e1; color: #e6a817; }
.stats-card { background: #fff; border-radius: 16rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,.06); }
.stats-row { display: flex; justify-content: space-around; }
.s-cell { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.s-num { font-size: 40rpx; font-weight: bold; color: #1F6FEB; }
.s-num.total { color: #333; }
.s-num.rate { font-size: 32rpx; color: #07c160; }
.s-label { font-size: 22rpx; color: #888; }
.section-title { font-size: 28rpx; font-weight: bold; color: #333; margin: 0 0 16rpx; }
.score-list { background: #fff; border-radius: 16rpx; overflow: hidden; box-shadow: 0 2rpx 12rpx rgba(0,0,0,.06); }
.score-row { display: flex; align-items: center; padding: 24rpx 32rpx; border-bottom: 1rpx solid #f0f0f0; gap: 20rpx; }
.score-row:last-child { border-bottom: none; }
.sr-rank { font-size: 28rpx; font-weight: bold; color: #1F6FEB; width: 40rpx; text-align: center; }
.sr-avatar { width: 64rpx; height: 64rpx; border-radius: 32rpx; background: #e8f0fe; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.sr-avatar-text { font-size: 28rpx; color: #1F6FEB; font-weight: bold; }
.sr-info { flex: 1; }
.sr-name { font-size: 28rpx; color: #333; display: block; }
.sr-rate { font-size: 22rpx; color: #888; display: block; margin-top: 4rpx; }
.sr-score { font-size: 30rpx; font-weight: bold; color: #1F6FEB; }
.empty-state { padding: 60rpx; text-align: center; color: #bbb; font-size: 26rpx; }
