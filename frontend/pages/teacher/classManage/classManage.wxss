.page-container {
  min-height: 100vh;
  background: #F4F7FB;
  padding: 24rpx;
  box-sizing: border-box;
}

/* 工具栏 */
.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.toolbar-title {
  font-size: 28rpx;
  color: #555;
  font-weight: 500;
}

.create-btn {
  background: #1F6FEB;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 14rpx 32rpx;
  border-radius: 32rpx;
}

/* 加载 */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-text {
  font-size: 26rpx;
  color: #aaa;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0 80rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  border: 4rpx dashed #c8d6e8;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-plus {
  font-size: 64rpx;
  color: #c8d6e8;
  line-height: 1;
}

.empty-title {
  font-size: 32rpx;
  color: #444;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #aaa;
  text-align: center;
}

/* 班级列表 */
.class-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.class-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, 0.06);
  overflow: hidden;
  box-sizing: border-box;
}

.class-card-actions {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #eef2f7;
}

.delete-btn {
  min-width: 104rpx;
  height: 52rpx;
  padding: 0 24rpx;
  border-radius: 26rpx;
  border: 2rpx solid #ffccc7;
  color: #f5222d;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  line-height: 1;
}

.delete-btn.disabled {
  color: #b8b8b8;
  border-color: #e8e8e8;
  background: #f7f7f7;
}

.class-card-body {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 162rpx;
}

.class-left {
  flex: 1;
}

.class-grade-tag {
  display: inline-block;
  font-size: 20rpx;
  color: #1F6FEB;
  background: #e8f0fe;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
}

.class-name {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #222;
  margin-bottom: 8rpx;
}

.class-meta {
  font-size: 24rpx;
  color: #999;
}

.class-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  flex-shrink: 0;
  max-width: 300rpx;
}

.code-label {
  font-size: 20rpx;
  color: #bbb;
}

.code-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #1F6FEB;
  letter-spacing: 4rpx;
}

.code-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.code-status.active {
  background: #e6f7f0;
  color: #07a65a;
}

.code-status.disabled {
  background: #f5f5f5;
  color: #aaa;
}

.no-code {
  font-size: 22rpx;
  color: #bbb;
}

.arrow-icon {
  font-size: 40rpx;
  color: #ccc;
  margin-top: 8rpx;
}

.delete-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.36);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
  z-index: 99;
}

.delete-dialog {
  width: 100%;
  max-width: 640rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 36rpx 32rpx;
  box-sizing: border-box;
  box-shadow: 0 24rpx 80rpx rgba(15, 23, 42, 0.18);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.delete-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #fff1f0;
  color: #f5222d;
  font-size: 40rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.delete-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 14rpx;
}

.delete-desc {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.6;
  text-align: center;
  margin-bottom: 32rpx;
}

.delete-actions {
  width: 100%;
  display: flex;
  gap: 20rpx;
}

.dialog-btn {
  flex: 1;
  height: 76rpx;
  border-radius: 38rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.dialog-btn.cancel {
  background: #f3f4f6;
  color: #4b5563;
}

.dialog-btn.danger {
  background: #f5222d;
  color: #fff;
}
