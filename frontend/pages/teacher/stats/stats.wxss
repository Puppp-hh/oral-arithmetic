.page-container { padding: 24rpx; background: #F4F7FB; min-height: 100vh; }
.loading-wrap { display: flex; justify-content: center; padding: 80rpx; color: #999; }
.section-title { font-size: 28rpx; font-weight: bold; color: #333; margin: 0 0 20rpx; }
.stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; margin-bottom: 32rpx; }
.stat-cell { background: #fff; border-radius: 16rpx; padding: 32rpx 24rpx; display: flex; flex-direction: column; align-items: center; gap: 12rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,.06); }
.cell-num { font-size: 44rpx; font-weight: bold; color: #1F6FEB; }
.cell-num.rate { color: #07c160; font-size: 36rpx; }
.cell-label { font-size: 24rpx; color: #888; }
.section-card { background: #fff; border-radius: 16rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,.06); }
.mistake-row { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; gap: 20rpx; }
.mistake-row:last-child { border-bottom: none; }
.rank-badge { width: 48rpx; height: 48rpx; border-radius: 24rpx; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: bold; flex-shrink: 0; background: #f0f0f0; color: #666; }
.rank-badge.rank-1 { background: #FFD700; color: #fff; }
.rank-badge.rank-2 { background: #C0C0C0; color: #fff; }
.rank-badge.rank-3 { background: #CD7F32; color: #fff; }
.mistake-info { flex: 1; }
.mistake-content { font-size: 28rpx; color: #333; display: block; }
.mistake-count { font-size: 22rpx; color: #e44d4d; display: block; margin-top: 4rpx; }
.empty-state { padding: 60rpx; text-align: center; color: #bbb; font-size: 26rpx; }
