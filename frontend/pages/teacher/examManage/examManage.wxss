.page-container { min-height: 100vh; background: #F4F7FB; }

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 44rpx 28rpx 18rpx;
}

.list-count { font-size: 24rpx; color: #999; }

.btn-create {
  background: #2d3a4a;
  color: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
  padding: 0 28rpx;
  height: 64rpx;
  border: none;
  line-height: 64rpx;
}

.list-wrap { padding: 18rpx 28rpx; }

.exam-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.exam-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.exam-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  flex: 1;
  margin-right: 16rpx;
}

.exam-meta { margin-bottom: 16rpx; }

.meta-item { font-size: 24rpx; color: #999; }

.exam-footer {
  display: flex;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.footer-item { font-size: 24rpx; color: #666; }
.footer-sep  { font-size: 24rpx; color: #ddd; margin: 0 12rpx; }
.footer-arrow { font-size: 24rpx; color: #ccc; margin-left: auto; }

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.tag-primary { background: #e8f0fe; color: #1F6FEB; }
.tag-warning { background: #fffbe6; color: #fa8c16; }
.tag-default { background: #f5f5f5; color: #999; }

.empty-state {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 300rpx;
  color: #bbb;
  font-size: 28rpx;
  gap: 24rpx;
}

.error-state {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  min-height: 320rpx;
  gap: 18rpx;
  color: #8a93a3;
  font-size: 26rpx;
}

.error-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2d3a4a;
}

.error-desc {
  max-width: 560rpx;
  text-align: center;
  line-height: 1.5;
}

.btn-retry {
  height: 64rpx;
  padding: 0 36rpx;
  border-radius: 32rpx;
  background: #2d3a4a;
  color: #fff;
  font-size: 26rpx;
  border: none;
  line-height: 64rpx;
}

.btn-empty-create {
  background: #2d3a4a;
  color: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
  padding: 0 40rpx;
  height: 72rpx;
  border: none;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
  color: #bbb;
  font-size: 26rpx;
}

.no-more { text-align: center; font-size: 24rpx; color: #ccc; padding: 32rpx 0; }
