<view class="page-container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input
      class="search-input"
      placeholder="搜索学生姓名或学号"
      value="{{keyword}}"
      bindinput="onSearchInput"
    />
  </view>

  <view class="list-header">
    <text class="list-count">共 {{total}} 位学生</text>
  </view>

  <view class="student-list">
    <view
      class="student-item"
      wx:for="{{list}}"
      wx:key="student_id"
      data-id="{{item.student_id}}"
      bindtap="goDetail"
    >
      <view class="s-avatar">
        <text class="s-avatar-text">{{item.avatarText}}</text>
      </view>
      <view class="s-info">
        <view class="s-name-row">
          <text class="s-name">{{item.name}}</text>
          <text class="s-account">{{item.account}}</text>
        </view>
        <view class="s-stats-row">
          <text class="s-level">Lv.{{item.current_level}} {{item.levelTitle}}</text>
          <text class="s-rate {{item.rateTone}}">{{item.rateText}}</text>
        </view>
        <text class="s-class">{{item.grade_name || ''}} {{item.class_name || ''}}</text>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{!loading && list.length === 0}}">
    <text>暂无学生数据</text>
  </view>

  <view class="loading-wrap" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <view class="no-more" wx:if="{{!loading && !hasMore && list.length > 0}}">
    <text>已加载全部</text>
  </view>
</view>
