/* 登录页样式 */
.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #4A90E2 0%, #6EC6FF 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx 40rpx;
  box-sizing: border-box;
}

/* ── 顶部 ── */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo-wrap {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255,255,255,0.25);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.logo-icon {
  font-size: 80rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 10rpx;
}

/* ── 角色选择 ── */
.role-tabs {
  display: flex;
  background: rgba(255,255,255,0.2);
  border-radius: 48rpx;
  padding: 6rpx;
  margin-bottom: 40rpx;
  width: 100%;
}

.role-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  transition: all 0.25s;
}

.role-tab.active {
  background: #fff;
  color: #4A90E2;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

/* ── 表单卡片 ── */
.form-card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 8rpx 32rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.12);
}

.input-group {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
}

.input-label {
  font-size: 28rpx;
  color: #666;
  width: 80rpx;
  flex-shrink: 0;
}

.input-field {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  padding: 0 16rpx;
}

.divider {
  height: 1rpx;
  background: #F5F5F5;
  margin: 0 -32rpx;
}

/* ── 登录按钮 ── */
.btn-login {
  width: 100%;
  background: #fff;
  color: #4A90E2;
  font-size: 34rpx;
  font-weight: 700;
  border-radius: 56rpx;
  padding: 28rpx 0;
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
  letter-spacing: 4rpx;
}

.btn-login.loading {
  opacity: 0.7;
}

.btn-login:active {
  transform: scale(0.97);
}

/* ── 提示 ── */
.tips {
  margin-top: 48rpx;
  color: rgba(255,255,255,0.7);
  font-size: 24rpx;
}
