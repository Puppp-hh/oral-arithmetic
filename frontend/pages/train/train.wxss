/* 训练页样式 */
.page { padding: 24rpx 24rpx 60rpx; }

/* ── 配置阶段 ── */
.config-header { padding: 24rpx 8rpx 32rpx; }
.config-title  { display: block; font-size: 40rpx; font-weight: 700; color: #333; }
.config-sub    { font-size: 26rpx; color: #999; margin-top: 8rpx; }

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
  margin-bottom: 32rpx;
}

.config-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
}

.config-label { font-size: 30rpx; color: #333; font-weight: 500; }
.picker-val   { font-size: 28rpx; color: #4A90E2; }

.level-slider { flex: 1; margin-left: 24rpx; }

.level-hint {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 8rpx 0 20rpx;
  font-size: 26rpx;
  color: #4A90E2;
  font-weight: 600;
}

.level-desc { color: #888; font-weight: 400; }

.divider { height: 1rpx; background: #F5F5F5; margin: 0 -32rpx; }

.btn-start {
  width: 100%;
  background: linear-gradient(135deg, #4A90E2, #357ABD);
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  border-radius: 56rpx;
  padding: 28rpx 0;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(74,144,226,0.4);
  letter-spacing: 4rpx;
}
.btn-start:active { opacity: 0.85; }

/* ── 训练阶段 ── */
.train-progress {
  margin-bottom: 24rpx;
}

.progress-text {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.timer-text { color: #4A90E2; font-weight: 600; }

.problem-card {
  background: linear-gradient(135deg, #4A90E2, #5BA3F5);
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(74,144,226,0.3);
  text-align: center;
}

.problem-meta {
  display: flex;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.problem-type {
  background: rgba(255,255,255,0.2);
  color: #fff;
  border-radius: 20rpx;
  padding: 6rpx 20rpx;
  font-size: 24rpx;
}

.problem-level {
  color: rgba(255,255,255,0.85);
  font-size: 26rpx;
}

.problem-content {
  font-size: 72rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 4rpx;
}

/* 答题区 */
.answer-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  display: flex;
  align-items: center;
}

.answer-label { font-size: 28rpx; color: #999; margin-right: 24rpx; }

.answer-input {
  flex: 1;
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  border-bottom: 3rpx solid #4A90E2;
  padding: 8rpx 16rpx;
}

.btn-submit {
  width: 100%;
  background: #4A90E2;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 56rpx;
  padding: 28rpx 0;
  border: none;
}
.btn-submit.loading { opacity: 0.7; }

/* 结果区 */
.result-card {
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.result-correct { background: #F6FFED; border: 2rpx solid #B7EB8F; }
.result-wrong   { background: #FFF2F0; border: 2rpx solid #FFCCC7; }

.result-icon { display: block; font-size: 64rpx; margin-bottom: 16rpx; }
.result-main { display: block; font-size: 36rpx; font-weight: 700; margin-bottom: 16rpx; }

.result-correct .result-main { color: #52C41A; }
.result-wrong   .result-main { color: #FF4D4F; }

.result-answer { font-size: 28rpx; color: #555; margin-bottom: 16rpx; }
.answer-highlight { font-size: 36rpx; font-weight: 800; color: #4A90E2; margin-left: 8rpx; }

.level-up-badge {
  background: linear-gradient(135deg, #F5A623, #FFD700);
  color: #fff;
  border-radius: 32rpx;
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  margin: 16rpx 0;
  display: inline-block;
}

.result-rate { font-size: 24rpx; color: #888; }

.btn-next {
  width: 100%;
  background: #4A90E2;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 56rpx;
  padding: 28rpx 0;
  border: none;
}

/* ── 汇总阶段 ── */
.summary-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 64rpx 40rpx;
  margin-bottom: 32rpx;
  text-align: center;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.08);
}

.summary-icon   { display: block; font-size: 96rpx; margin-bottom: 24rpx; }
.summary-title  { display: block; font-size: 40rpx; font-weight: 700; color: #333; margin-bottom: 16rpx; }
.summary-sub    { display: block; font-size: 32rpx; color: #4A90E2; font-weight: 600; margin-bottom: 16rpx; }
.summary-tip    { font-size: 26rpx; color: #999; }

.btn-primary-full {
  width: 100%;
  background: #4A90E2;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 56rpx;
  padding: 28rpx 0;
  border: none;
  margin-bottom: 20rpx;
}

.btn-ghost-full {
  width: 100%;
  background: transparent;
  color: #4A90E2;
  font-size: 32rpx;
  border: 2rpx solid #4A90E2;
  border-radius: 56rpx;
  padding: 26rpx 0;
}
