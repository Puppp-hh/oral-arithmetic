/* 全局基础样式 */

page {
  background-color: #f5f5f7;
  font-family: -apple-system, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #1d1d1f;
  box-sizing: border-box;
}

/* 通用容器 */
.page-container {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.04);
}

/* 主色按钮 */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  background: #007aff;
  color: #fff;
  border-radius: 18rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.btn-primary[disabled] {
  background: #a9d3ff;
}

/* 次级按钮 */
.btn-default {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  background: #fff;
  color: #007aff;
  border-radius: 18rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: 1rpx solid rgba(0, 122, 255, 0.28);
}

/* 状态标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.6;
}

.tag-success { background: #e8f8ef; color: #128a4a; }
.tag-danger  { background: #fff0f0; color: #d92d20; }
.tag-warning { background: #fff6e0; color: #b85d00; }
.tag-primary { background: #e9f3ff; color: #007aff; }
.tag-default { background: #f2f2f7; color: #6e6e73; }

/* 分割线 */
.divider {
  height: 1rpx;
  background: rgba(0, 0, 0, 0.08);
  margin: 24rpx 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  color: #8e8e93;
  font-size: 28rpx;
}

.empty-state image {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.list-item:last-child {
  border-bottom: none;
}

/* 正确/错误反馈色 */
.text-success { color: #128a4a; }
.text-danger  { color: #d92d20; }
.text-primary { color: #007aff; }
.text-muted   { color: #6e6e73; }

/* 居中 */
.text-center { text-align: center; }

/* 加载占位 */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 200rpx;
  color: #8e8e93;
  font-size: 26rpx;
}
